{
  "name": "aws-serverless-api-backend-lambdas",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Lambda handlers for the AWS serverless items API.",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.896.0",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "scripts": {
    "artifacts:verify": "node scripts/verify-lambda-artifacts.mjs",
    "build": "tsc",
    "contract:validate": "node scripts/validate-openapi.mjs",
    "smoke:test": "node ../scripts/smoke-test.mjs",
    "test": "vitest run",
    "test:contract": "vitest run __tests__/contract",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^22.19.19",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "ajv": "^8.17.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9",
    "yaml": "^2.8.1",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "overrides": {
    "fast-xml-parser": "5.8.0"
  },
  "license": "ISC"
}
